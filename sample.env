# ── LLM ──────────────────────────────────────────────────────────────────────

# Anthropic
# LLM_PROVIDER=anthropic
# LLM_MODEL=claude-sonnet-4-5
# ANTHROPIC_API_KEY=

# OpenRouter
# LLM_PROVIDER=openrouter
# LLM_MODEL=anthropic/claude-sonnet-4-5
# OPENROUTER_API_KEY=

# Local OpenAI-compatible
# LLM_PROVIDER=local
# LOCAL_MODEL_URL=http://host.docker.internal:11434/v1
# LLM_MODEL=

# Ollama OpenAI-compatible
# LLM_PROVIDER=local
# LOCAL_MODEL_URL=https://ollama.com/v1
# LOCAL_MODEL_API_KEY=
# LLM_MODEL=qwen3-coder:480b-cloud

# Optional overrides
# ANTHROPIC_BASE_URL=
# LLM_TIMEOUT_SECONDS=60

# ── WhatsApp ──────────────────────────────────────────────────────────────────

MY_WHATSAPP_NUMBER=

# ── Temporal ──────────────────────────────────────────────────────────────────

TEMPORAL_ADDRESS=temporal:7233

# ── Docker / Temporal stack versions ─────────────────────────────────────────

TEMPORAL_VERSION=1.29.1
TEMPORAL_ADMINTOOLS_VERSION=1.29.1-tctl-1.18.4-cli-1.5.0
TEMPORAL_UI_VERSION=2.34.0
POSTGRESQL_VERSION=16
ELASTICSEARCH_VERSION=7.17.27

# ── Tuning (optional) ─────────────────────────────────────────────────────────

# WORKFLOW_TIMEOUT_MINUTES=60
# HEARTBEAT_INTERVAL_MINUTES=30
# COMPACTION_THRESHOLD=50
# COMPACTION_KEEP_RECENT=2
# SUB_AGENT_MAX_ITERATIONS=10
# SUB_AGENT_TIMEOUT_MINUTES=10
