
# Your WhatsApp phone number (digits only, e.g. 1234567890)
MY_WHATSAPP_NUMBER=1234567890

# Temporal
TEMPORAL_ADDRESS=localhost:7233

WORKFLOW_TIMEOUT_MINUTES=15

# OLLAMA
# Local/Ollama (set LLM_PROVIDER=local to use)
# LLM_PROVIDER=local
# LOCAL_MODEL_URL=https://ollama.com/v1
# LOCAL_MODEL_API_KEY=...
# LLM_MODEL=qwen3-coder:480b-cloud

# LLM
# for local model, you might want to refer to localhost as host.docker.internal instead
# when running the worker inside a container
LOCAL_MODEL_URL=http://host.docker.internal:8888/v1
LLM_PROVIDER=openrouter
LLM_MODEL=openrouter/free

ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=

OPENROUTER_API_KEY=




# WhatsApp (Neonize) — optional, defaults shown
NEONIZE_DB_PATH=./neonize.db

# Workflow
WORKFLOW_MAX_DURATION_MINUTES=60
HEARTBEAT_INTERVAL_MINUTES=30

# Temporal Infrastructure (for docker-compose)
COMPOSE_PROJECT_NAME=temporal
POSTGRESQL_VERSION=16
POSTGRES_PASSWORD=temporal
POSTGRES_USER=temporal
POSTGRES_DEFAULT_PORT=5432
TEMPORAL_VERSION=1.29.1
TEMPORAL_ADMINTOOLS_VERSION=1.29.1-tctl-1.18.4-cli-1.5.0
TEMPORAL_UI_VERSION=2.34.0
