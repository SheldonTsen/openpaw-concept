FROM python:3.13-slim

# Install system dependencies (libmagic needed by python-magic, a neonize dep)
RUN apt-get update && apt-get install -y --no-install-recommends libmagic1 && rm -rf /var/lib/apt/lists/*

# Install uv
COPY --from=ghcr.io/astral-sh/uv:latest /uv /uvx /bin/

WORKDIR /app

# Copy dependency files first (layer caching)
COPY pyproject.toml uv.lock* ./

# Install all dependencies including dev (watchdog for hot reload)
RUN uv sync --no-install-project

# Copy source code
COPY src/ src/

# Install the project itself
RUN uv sync

# Hot reload: watchdog restarts on .py file changes
CMD ["uv", "run", "watchmedo", "auto-restart", \
     "--directory", "src", \
     "--pattern", "*.py", \
     "--recursive", \
     "--", "uv", "run", "python", "-m", "src"]
